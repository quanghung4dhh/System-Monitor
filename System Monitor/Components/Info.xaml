<UserControl
  x:Class="System_Monitor.Components.Info"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:System_Monitor.Components"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  d:DesignHeight="450"
  d:DesignWidth="800"
  mc:Ignorable="d">
  <UserControl.Resources>
    <local:UsageToColorConverter x:Key="ColorConverter" />
  </UserControl.Resources>
  <Grid>
    <StackPanel>
      <TextBlock Margin="0,0,0,20" FontSize="25">
        <Run Text="Name: " />
        <Run Text="{Binding Path=DeviceName, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" />
      </TextBlock>
      <TextBlock Margin="0,0,0,10" FontSize="25">
        <Run Text="Usage: " />
        <Run Text="{Binding Path=Usage, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" />
        <Run Text="%" />
      </TextBlock>
      <ProgressBar
        Height="15"
        Margin="0,0,0,20"
        Foreground="{Binding Path=Usage, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Converter={StaticResource ColorConverter}}"
        Maximum="100"
        Minimum="0"
        Value="{Binding Path=Usage, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" />
      <TextBlock Margin="0,0,0,10" FontSize="25">
        <Run Text="Temp: " />
        <Run Text="{Binding Path=Temp, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" />
        <Run Text="°C" />
      </TextBlock>
      <ProgressBar
        Height="15"
        Foreground="{Binding Path=Temp, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Converter={StaticResource ColorConverter}}"
        Maximum="100"
        Minimum="0"
        Value="{Binding Path=Temp, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" />

    </StackPanel>

  </Grid>
</UserControl>
