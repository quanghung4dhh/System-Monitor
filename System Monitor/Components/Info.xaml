<UserControl
  x:Class="System_Monitor.Components.Info"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:System_Monitor.Components"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  d:DesignHeight="450"
  d:DesignWidth="800"
  mc:Ignorable="d">
  <Grid>
    <StackPanel>
      <TextBlock FontSize="25">
        <Run Text="Name: " />
        <Run Text="{Binding Path=Name, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" />
      </TextBlock>
      <TextBlock FontSize="25">
        <Run Text="Usage: " />
        <Run Text="{Binding Path=Usage, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" />
        <Run Text="%" />
      </TextBlock>
      <TextBlock FontSize="25">
        <Run Text="Temp: " />
        <Run Text="{Binding Path=Temp, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" />
        <Run Text="°C" />
      </TextBlock>

    </StackPanel>

  </Grid>
</UserControl>
