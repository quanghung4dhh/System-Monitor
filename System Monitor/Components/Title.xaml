<UserControl
  x:Class="System_Monitor.Components.Title"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:System_Monitor.Components"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  x:Name="Card"
  d:DesignHeight="450"
  d:DesignWidth="800"
  mc:Ignorable="d">
  <Grid>
    <TextBlock Text="{Binding Path=TextTitle, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" />
  </Grid>
</UserControl>
