<Window
  x:Class="System_Monitor.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:comp="clr-namespace:System_Monitor.Components"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:System_Monitor"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  Title="System Monitor"
  Width="1080"
  Height="720"
  FontFamily="Consolas"
  Icon="/assets/icon.ico"
  mc:Ignorable="d">
  <Grid Width="1080" HorizontalAlignment="Left">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="31*" />
      <ColumnDefinition Width="69*" />
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="*" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <comp:Title
      Grid.RowSpan="2"
      Grid.ColumnSpan="2"
      Margin="20,16,745,234"
      FontSize="30"
      TextTitle="CPU" />
    <comp:Title
      Grid.Row="1"
      Grid.ColumnSpan="2"
      Margin="20,16,745,0"
      FontSize="30"
      TextTitle="RAM" />
    <comp:Title
      Grid.Row="2"
      Grid.ColumnSpan="2"
      Margin="20,7,745,10"
      FontSize="30"
      TextTitle="GPU" />
    <comp:Info Card="CPU" Margin="76,47,544,31" Grid.Column="1" Loaded="Info_Loaded" />
    <comp:Info Card="RAM" Margin="76,47,540,31" Grid.Column="1" Loaded="Info_Loaded" Grid.Row="1" />
    <comp:Info Card="GPU" Margin="48,39,571,39" Grid.Column="1" Loaded="Info_Loaded" Grid.Row="2" />
  </Grid>
</Window>
