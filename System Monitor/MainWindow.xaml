<Window
  x:Class="System_Monitor.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:comp="clr-namespace:System_Monitor.Components"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="clr-namespace:System_Monitor"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  Title="System Monitor"
  Width="1080"
  Height="720"
  FontFamily="Consolas"
  Icon="/assets/icon.ico"
  mc:Ignorable="d">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="*" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <Border
      Grid.Row="0"
      Background="White"
      BorderBrush="#000"
      BorderThickness="1,1,1,1">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="31*" />
          <ColumnDefinition Width="69*" />
        </Grid.ColumnDefinitions>
        <Border
          Grid.Column="0"
          BorderBrush="#000"
          BorderThickness="0,0,1,0">
          <comp:Title
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="50"
            TextTitle="CPU" />
        </Border>

        <comp:Info
          Grid.Column="1"
          Margin="20,20,20,20"
          Card="CPU"
          Loaded="Info_Loaded" />
      </Grid>
    </Border>
    <Border
      Grid.Row="1"
      Background="White"
      BorderBrush="#000"
      BorderThickness="1,0,1,1">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="31*" />
          <ColumnDefinition Width="69*" />
        </Grid.ColumnDefinitions>
        <Border
          Grid.Column="0"
          BorderBrush="#000"
          BorderThickness="0,0,1,0">
          <comp:Title
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="50"
            TextTitle="RAM" />
        </Border>

        <comp:Info
          Grid.Column="1"
          Margin="20,20,20,20"
          Card="RAM"
          Loaded="Info_Loaded" />
      </Grid>
    </Border>
    <Border
      Grid.Row="2"
      Background="White"
      BorderBrush="#000"
      BorderThickness="1,0,1,1">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="31*" />
          <ColumnDefinition Width="69*" />
        </Grid.ColumnDefinitions>
        <Border
          Grid.Column="0"
          BorderBrush="#000"
          BorderThickness="0,0,1,0">
          <comp:Title
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="50"
            TextTitle="GPU" />
        </Border>

        <comp:Info
          Grid.Column="1"
          Margin="20,20,20,20"
          Card="GPU"
          Loaded="Info_Loaded" />
      </Grid>
    </Border>


  </Grid>
</Window>
